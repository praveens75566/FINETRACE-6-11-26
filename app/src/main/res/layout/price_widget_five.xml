<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FinTrace 5 Tracker"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <ImageView
            android:id="@+id/widget_status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_toEndOf="@id/widget_title"
            android:layout_marginStart="6dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_circle_status" />

        <ImageButton
            android:id="@+id/widget_btn_refresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_sync"
            android:contentDescription="Refresh All" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginBottom="6dp" />

    <!-- 5 Rows of Symbols -->
    <!-- Row 1 -->
    <RelativeLayout
        android:id="@+id/row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/text_symbol_1_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYM1"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />
        <TextView
            android:id="@+id/text_symbol_1_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="#69F0AE"
            android:textSize="11sp"
            android:layout_alignParentEnd="true" />
        <TextView
            android:id="@+id/text_symbol_1_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/text_symbol_1_change"
            android:layout_marginEnd="6dp" />
    </RelativeLayout>

    <!-- Row 2 -->
    <RelativeLayout
        android:id="@+id/row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/text_symbol_2_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYM2"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />
        <TextView
            android:id="@+id/text_symbol_2_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="#69F0AE"
            android:textSize="11sp"
            android:layout_alignParentEnd="true" />
        <TextView
            android:id="@+id/text_symbol_2_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/text_symbol_2_change"
            android:layout_marginEnd="6dp" />
    </RelativeLayout>

    <!-- Row 3 -->
    <RelativeLayout
        android:id="@+id/row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/text_symbol_3_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYM3"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />
        <TextView
            android:id="@+id/text_symbol_3_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="#69F0AE"
            android:textSize="11sp"
            android:layout_alignParentEnd="true" />
        <TextView
            android:id="@+id/text_symbol_3_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/text_symbol_3_change"
            android:layout_marginEnd="6dp" />
    </RelativeLayout>

    <!-- Row 4 -->
    <RelativeLayout
        android:id="@+id/row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/text_symbol_4_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYM4"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />
        <TextView
            android:id="@+id/text_symbol_4_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="#69F0AE"
            android:textSize="11sp"
            android:layout_alignParentEnd="true" />
        <TextView
            android:id="@+id/text_symbol_4_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/text_symbol_4_change"
            android:layout_marginEnd="6dp" />
    </RelativeLayout>

    <!-- Row 5 -->
    <RelativeLayout
        android:id="@+id/row_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">
        <TextView
            android:id="@+id/text_symbol_5_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYM5"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />
        <TextView
            android:id="@+id/text_symbol_5_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00%"
            android:textColor="#69F0AE"
            android:textSize="11sp"
            android:layout_alignParentEnd="true" />
        <TextView
            android:id="@+id/text_symbol_5_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/text_symbol_5_change"
            android:layout_marginEnd="6dp" />
    </RelativeLayout>
</LinearLayout>
